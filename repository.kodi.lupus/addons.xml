<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="repository.kodi.lupus" name="Lupus Kodi Repo" version="1.0.1" provider-name="Lupus">
    <extension point="xbmc.addon.repository" name="Lupus Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/lupusaesticus/repository.kodi.lupus/main/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/lupusaesticus/repository.kodi.lupus/main/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/lupusaesticus/repository.kodi.lupus/main/zips/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Lupus Kodi Addons</summary>
        <description>Repository for Lasteekraan addon and future kodi projects.</description>
        <platform>all</platform>
    </extension>
</addon>
<addon id="plugin.video.lasteekraan.err.ee"
       name="Lasteekraan"
       version="1.1.0"
       provider-name="Lupus (github.com/lupusaesticus)">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.inputstreamhelper" version="0.3.3"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="lasteekraan_addon.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Lasteekraan ERR content for children</summary>
    <summary lang="et_EE">Lasteekraani sisu lastele</summary>
    <description lang="en_GB">Watch children's shows from ERR Lasteekraan</description>
    <description lang="et_EE">Vaata Lasteekraani saateid</description>
    <platform>all</platform>
    <license>GPL-3.0-only</license>
    <website>https://lasteekraan.err.ee</website>
    <source>https://github.com/lupusaesticus/plugin.video.lasteekraan.err.ee</source>
    <news>v1.1.0 - Added alphabetical sorting, reporting error message for geoblocked content</news>
    <assets>
      <icon>resources/logo.png</icon>
      <fanart>resources/fanart.jpg</fanart>
    </assets>
  </extension>
</addon>

</addons>
